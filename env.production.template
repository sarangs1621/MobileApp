###############################################################################
# SCHOOL PORTAL — PRODUCTION .env TEMPLATE
#
# Copy to `.env` at the repo root and fill every REQUIRED value:
#     cp env.production.template .env
#
# This root .env is read by the ops scripts (bootstrap/provision/verify) and by
# the production deploy (docker-compose.prod.yml).
#
# For LOCAL dev the apps read their own files instead:
#   - Web:    apps/web/.env.local   (APP_ENV, DATABASE_URL, SUPABASE_*, NEXT_PUBLIC_*)
#   - Mobile: apps/mobile/.env      (EXPO_PUBLIC_* only)
#
# NEVER commit the filled-in .env. It is gitignored on purpose.
# Values are validated fail-fast at runtime (apps/web/src/env.ts, apps/mobile/src/env.ts).
###############################################################################


# ============================================================================
# 1. CORE — WEB / SERVER  (all REQUIRED)
# ============================================================================

# development | staging | production
APP_ENV=production

# Deploy version shown at GET /api/health. Set to the git SHA or tag at deploy.
# Optional; defaults to "unknown".
APP_VERSION=

# Postgres connection (Supabase).
# Use the SESSION POOLER string, port 5432. URL-encode special chars in the
# password (e.g. '#' -> '%23').
# NOTE: for pg_dump / prisma migrate you may prefer the DIRECT connection URL.
DATABASE_URL=postgresql://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Supabase service_role key — SERVER-ONLY secret. Mints signed storage URLs,
# powers the /api/ready storage check and the Admin-API provisioning scripts.
# NEVER expose as NEXT_PUBLIC_ / EXPO_PUBLIC_ (importing it client-side is a build error).
SUPABASE_SERVICE_ROLE=

# Supabase project URL + anon (public) key — safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ============================================================================
# 2. PUSH NOTIFICATIONS  (server side of the go-live switch)
# ============================================================================

# "true" wires the Expo push adapter + fan-out. Unset/false => in-app only, zero
# push delivery. The OTHER half of this switch is the EAS projectId in
# apps/mobile/app.json -> extra.eas.projectId (both must be set to deliver push).
PUSH_NOTIFICATIONS_ENABLED=true

# Optional — Expo's enhanced push-security access token. Push works without it.
EXPO_ACCESS_TOKEN=


# ============================================================================
# 3. CORE — MOBILE (Expo)   (all REQUIRED; only EXPO_PUBLIC_* is bundled)
# For a production build these live in apps/mobile/.env (or EAS secrets).
# ============================================================================

EXPO_PUBLIC_APP_ENV=production

# Same Supabase project URL + anon key as the web side above.
EXPO_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of the deployed web app (it hosts the tRPC API). Your real domain.
# e.g. https://portal.yourschool.example
EXPO_PUBLIC_API_URL=https://<your-web-domain>


# ============================================================================
# 4. OPS / BOOTSTRAP SCRIPTS
#   pnpm --filter @repo/business run bootstrap   (creates school + super-admin)
#   pnpm --filter @repo/business run verify:auth (live auth check)
# ============================================================================

SEED_SCHOOL_NAME=Your School Name
SEED_SUPER_ADMIN_EMAIL=admin@yourschool.example
# Choose a strong password, >= 10 chars.
SEED_SUPER_ADMIN_PASSWORD=

# Must EXACTLY match the Supabase test-OTP config so verify:auth passes.
# Test numbers receive no SMS — you type the configured code.
TEST_OTP_PHONE=+919999900001
TEST_OTP_CODE=123456

# Optional — password used by scripts/verify-auth.ts signup probe.
# Defaults to a random UUID per run; leave blank unless you need it fixed.
AUTH_PROBE_PASSWORD=


# ============================================================================
# 5. SMS PROVIDER (parent OTP)  —  NOT set here!
# ============================================================================
# Twilio credentials (Account SID / Auth Token / Messaging Service SID) are
# configured in SUPABASE, not in this file — via the dashboard or the Auth
# Management API (see docs/RUNBOOK_SUPABASE_SETUP.md §2):
#     sms_provider = "twilio"
#     sms_twilio_account_sid / _auth_token / _message_service_sid
# India production also requires TRAI DLT registration (entity + templates).
#
# The MSG91 / Gupshup keys below are only for the optional in-app send-SMS hook
# path; the primary OTP path is Supabase-native (Twilio) above.


# ============================================================================
# 6. INTEGRATIONS — fill the ones you use (uncomment as the module is enabled)
# ============================================================================

# --- Custom SMTP for auth emails (password reset / staff invites) ---
# Pre-production blocker: Supabase built-in email has a tiny hourly cap.
# RESEND_API_KEY=

# --- Alternative Indian SMS providers (optional; see §5) ---
# MSG91_API_KEY=
# GUPSHUP_API_KEY=

# --- Payments (NOT used in v1 — fees are read-only reference) ---
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# --- Monitoring / analytics (recommended, optional) ---
# SENTRY_DSN=
# POSTHOG_KEY=


# ============================================================================
# 7. LOCAL docker-compose Postgres  —  DEV ONLY (do NOT use in production;
#    production DB is Supabase via DATABASE_URL above)
# ============================================================================
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=school_portal


# ============================================================================
# NOTE: SKIP_ENV_VALIDATION is a CI-only flag. Do NOT set it in production —
# you WANT fail-fast validation of the values above at runtime.
# ============================================================================
