// Prisma schema — M1 (authentication foundation) + M2 (academic structure).
//
// M1: tenant root (School) + identity (User) + devices (DeviceToken) + audit
// (AuditLog) + auth enums. M2: AcademicYear/AcademicTerm (time axis) and
// Class/Section/Subject (structure axis) joined by TeacherAssignment.
// Students, enrollment, attendance, exams, people records land in later
// milestones per the M2 kickoff brief.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- enums ----------
enum Role {
  SUPER_ADMIN
  OFFICE_ADMIN
  TEACHER
  PARENT
  ACCOUNTANT
}

enum UserStatus {
  INVITED // provisioned, not yet signed in
  ACTIVE // activated on first successful sign-in
  DISABLED // soft-disabled; history preserved, access revoked
}

enum Locale {
  EN
  ML
}

// ---------- tenant ----------
// Single-tenant today. `schoolId` is a LOOSE scalar on other tables (ADR-008),
// so School has no back-relations; it is the tenant root the seed creates.
model School {
  id            String   @id @default(cuid())
  name          String
  address       String?
  logoUrl       String?
  defaultLocale Locale   @default(EN)
  settings      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  // + raw SQL: RLS ON — admin read only (m1_rls_hardening; defense-in-depth)
}

// ---------- identity (profile keyed to the Supabase auth UID) ----------
// `id` == Supabase `auth.users.id` — no separate PK, no default (the UID is
// supplied at provisioning). Credentials/OTP live in Supabase; we store none.
model User {
  id                 String              @id
  schoolId           String // loose tenant ref (ADR-008)
  role               Role
  status             UserStatus          @default(INVITED)
  phone              String?             @unique
  email              String?             @unique
  locale             Locale              @default(EN)
  lastLoginAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deviceTokens       DeviceToken[]
  // Virtual back-relations only (no column/behavior change to the frozen M1 model).
  teacherAssignments TeacherAssignment[]
  staff              Staff? // M3: employment profile, 1:1 (userId unique on Staff)
  parent             Parent? // M3: parent portal login, 1:1 (userId unique on Parent)
  // + raw SQL: RLS ON — read-self + admin-read-all (m1_rls_hardening)

  @@index([schoolId, role])
}

// ---------- devices ----------
// Table designed in M1 (per the milestone's model list); device REGISTRATION and
// push delivery are deferred to the Notifications milestone (no registerDevice yet).
model DeviceToken {
  id            String   @id @default(cuid())
  userId        String
  expoPushToken String   @unique
  platform      String
  lastSeenAt    DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // + raw SQL: RLS ON — owner read only (m1_rls_hardening)

  @@index([userId])
}

// ---------- academic structure (M2) ----------

// Lifecycle of a year: PLANNED (setup) → ACTIVE (in session; exactly one per
// school, enforced by a partial unique index — raw SQL, ADR-009) → CLOSED
// (terminal; year + terms locked). Rollover flips old→CLOSED, new→ACTIVE in
// one transaction.
enum AcademicYearStatus {
  PLANNED
  ACTIVE
  CLOSED
}

// TIME axis root, e.g. "2026–27". Calendar dates are @db.Date (IST convention,
// Dev PRD decision #22) so range logic can't drift by a UTC off-by-one.
model AcademicYear {
  id                 String              @id @default(cuid())
  schoolId           String // loose tenant ref (ADR-008)
  name               String
  startDate          DateTime            @db.Date
  endDate            DateTime            @db.Date
  status             AcademicYearStatus  @default(PLANNED)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  terms              AcademicTerm[]
  enrollments        Enrollment[] // M3: virtual back-relation only (no change to frozen M2 model)
  holidays           Holiday[] // M4: virtual back-relation only (no change to frozen M2 model)
  attendanceSessions AttendanceSession[] // M4: virtual back-relation only
  // + raw SQL: UNIQUE (schoolId) WHERE status = 'ACTIVE'  — one ACTIVE year
  // + raw SQL: CHECK (startDate < endDate)
  // + raw SQL: RLS ON — admin-only ALL (academic_rls migration; defense-in-depth)

  @@unique([schoolId, name])
  @@index([schoolId, status])
}

// Subdivision of a year, e.g. "Term 1". Sibling terms must not overlap
// (inclusive dates) — enforced by an EXCLUDE USING gist constraint (raw SQL)
// plus the business-layer check; ordering derives from startDate.
model AcademicTerm {
  id             String       @id @default(cuid())
  academicYearId String
  name           String
  startDate      DateTime     @db.Date
  endDate        DateTime     @db.Date
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  // + raw SQL: EXCLUDE USING gist (academicYearId =, daterange(start,end,'[]') &&)
  // + raw SQL: CHECK (startDate < endDate)
  // + raw SQL: RLS ON — admin-only ALL (academic_rls migration)

  @@unique([academicYearId, name])
  @@index([academicYearId, startDate])
}

// STRUCTURE axis: a grade level ("Grade 5"). Persistent across years —
// enrollment (M3) binds student × section × year. sortOrder gives deterministic
// display order ("Grade 10" would otherwise sort before "Grade 2").
model Class {
  id          String       @id @default(cuid())
  schoolId    String // loose tenant ref (ADR-008)
  name        String
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  sections    Section[]
  enrollments Enrollment[] // M3: virtual back-relation only (no change to frozen M2 model)
  // + raw SQL: RLS ON — admin-only ALL (academic_rls migration)

  @@unique([schoolId, name])
  @@index([schoolId, sortOrder])
}

// Parallel group within a class ("A", "B"). Restrict delete from Class: a class
// with sections must be emptied deliberately (no cascade data loss).
model Section {
  id                 String              @id @default(cuid())
  classId            String
  name               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  class              Class               @relation(fields: [classId], references: [id], onDelete: Restrict)
  teacherAssignments TeacherAssignment[]
  enrollments        Enrollment[] // M3: virtual back-relation only (no change to frozen M2 model)
  attendanceSessions AttendanceSession[] // M4: virtual back-relation only
  // + raw SQL: RLS ON — admin-only ALL (academic_rls migration)

  @@unique([classId, name])
}

// School-wide subject catalog ("Gujarati", "Mathematics") — a sibling of the
// Class tree, meeting sections only through TeacherAssignment.
model Subject {
  id                 String              @id @default(cuid())
  schoolId           String // loose tenant ref (ADR-008)
  name               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  teacherAssignments TeacherAssignment[]
  attendanceSessions AttendanceSession[] // M4: virtual back-relation only
  // + raw SQL: RLS ON — admin-only ALL (academic_rls migration)

  @@unique([schoolId, name])
}

// The operational unit: teacher × subject × section. teacherId references
// User directly (no Staff table in M2); the role/status check is business-layer.
// Immutable — no update; staffing changes are audited delete + create. NOT
// year-scoped per the M2 brief (unique triple below); year scoping is an
// additive migration if a later milestone needs assignment history.
// No isClassTeacher flag yet (later milestone).
model TeacherAssignment {
  id        String   @id @default(cuid())
  schoolId  String // denormalized loose tenant ref — scope queries + audit (ADR-008)
  teacherId String
  subjectId String
  sectionId String
  createdAt DateTime @default(now())
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  // + raw SQL: RLS ON — admin ALL + teacher SELECT own (teacherId = auth.uid())

  @@unique([teacherId, subjectId, sectionId])
  @@index([sectionId])
  @@index([subjectId])
  @@index([schoolId])
}

// ---------- audit (append-only) ----------
// Loose actor/entity refs on purpose — append-only history that outlives the rows
// it describes; entityType+entityId is polymorphic (ADR-007). Written by services
// for role/user changes (setRole, disableUser) in the same transaction.
model AuditLog {
  id          String   @id @default(cuid())
  schoolId    String
  actorUserId String
  action      String
  entityType  String
  entityId    String
  beforeJson  Json?
  afterJson   Json?
  createdAt   DateTime @default(now())
  // + raw SQL: RLS ON — admin read only (m1_rls_hardening)

  @@index([entityType, entityId])
  @@index([schoolId, createdAt])
}

// ========================= People Management (M3) =========================
// Student = IDENTITY ONLY (no class/section/year). Enrollment owns per-year
// placement (ADR-010). Two lifecycle axes kept separate: Student.status (the
// person) vs EnrollmentStatus (the year's placement). Names diverge from the
// DEV_PRD deliberately (Parent not Guardian) — approved M3 decision.

// ---------- enums ----------
enum Gender {
  MALE
  FEMALE
  OTHER
}

// Person-level lifecycle. Distinct from EnrollmentStatus. No soft-delete column
// (DATABASE_CONVENTIONS §3) — ARCHIVED/WITHDRAWN/GRADUATED carry the reason.
enum StudentStatus {
  ACTIVE
  ARCHIVED
  GRADUATED
  WITHDRAWN
}

// Per-(student,parent) relationship — lives on the junction so one person can be
// FATHER to one child and GUARDIAN/EMERGENCY_CONTACT to another.
enum StudentRelationship {
  FATHER
  MOTHER
  GUARDIAN
  EMERGENCY_CONTACT
}

enum PreferredContact {
  PHONE
  EMAIL
  WHATSAPP
}

// DOCUMENT VISIBILITY (business-layer authorization; RLS is unchanged and only
// governs WHO reaches a student's docs). StudentDocumentService filters WHICH
// types are returned by role:
//   TEACHER            → PHOTO only (all other types hidden)
//   PARENT (own child) → all types
//   OFFICE_ADMIN / SUPER_ADMIN → all types
// Never expose MEDICAL_RECORD to teachers — if teachers ever need medical info,
// add a dedicated Medical Summary feature, not access to the uploaded files.
enum StudentDocumentType {
  BIRTH_CERTIFICATE
  PASSPORT
  AADHAAR
  MEDICAL_RECORD
  TRANSFER_CERTIFICATE
  PHOTO // the ONLY teacher-visible type
  OTHER
}

// Year-placement lifecycle (ADR-010). ADMITTED → ACTIVE → one terminal state.
enum EnrollmentStatus {
  ADMITTED
  ACTIVE
  PROMOTED
  RETAINED
  TRANSFERRED
  DROPPED
  ALUMNI
}

// ---------- student (identity) ----------
// admissionNo unique per school; calendar dob is @db.Date (IST convention, no
// UTC off-by-one). photoPath is a PRIVATE storage path signed on read (ADR-004).
model Student {
  id          String            @id @default(cuid())
  schoolId    String // loose tenant ref (ADR-008)
  admissionNo String
  firstName   String
  lastName    String
  dob         DateTime?         @db.Date
  gender      Gender?
  bloodGroup  String?
  nationality String?
  aadhaar     String? // optional national ID; sensitive — unique per school when present (raw SQL below)
  passport    String?
  address     String?
  photoPath   String? // PRIVATE storage path, signed on read (ADR-004)
  status      StudentStatus     @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  enrollments Enrollment[]
  parents     StudentParent[]
  documents   StudentDocument[]
  // + raw SQL: partial unique — Aadhaar unique per school when present:
  //   WHERE "aadhaar" IS NOT NULL  (a shared national ID is a data error)
  // + raw SQL: RLS ON — admin ALL; teacher SELECT own-section; parent SELECT own-child (people_rls, Step 4)

  @@unique([schoolId, admissionNo])
  @@index([schoolId, status])
  @@index([schoolId, lastName, firstName]) // roster search/sort
}

// ---------- student documents (metadata; bytes live in Supabase Storage) ----------
// version is versioning-ready: replace bumps version (no unique on (student,type),
// so historical versions coexist — full history table is a later concern).
// Retrieval = storagePath (signed on read). Validation = mimeType + sizeBytes +
// optional checksum (SHA-256 hex; integrity check on download). uploadedAt is
// `createdAt` — the row is written at upload time.
model StudentDocument {
  id               String              @id @default(cuid())
  schoolId         String // loose tenant ref (ADR-008)
  studentId        String
  type             StudentDocumentType
  storagePath      String // PRIVATE bucket path (ADR-004), signed on read
  fileName         String
  mimeType         String?
  sizeBytes        Int?
  checksum         String? // optional SHA-256 hex — verify integrity on download
  version          Int                 @default(1)
  uploadedByUserId String // actor (loose ref — append-only-ish metadata)
  createdAt        DateTime            @default(now()) // == uploadedAt
  student          Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  // + raw SQL: RLS ON — mirrors Student visibility (people_rls, Step 4)

  @@index([studentId, type])
  @@index([schoolId])
}

// ---------- parent (contact / guardian) ----------
// userId NULLABLE: an app-login parent (Role=PARENT) carries the Supabase uid for
// RLS parent-scope; an emergency-only contact has null uid and no portal access.
// SetNull (not Cascade): removing the login keeps the contact record.
model Parent {
  id               String           @id @default(cuid())
  schoolId         String // loose tenant ref (ADR-008)
  userId           String?          @unique
  name             String
  phone            String
  email            String?
  occupation       String?
  address          String?
  preferredContact PreferredContact @default(PHONE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  students         StudentParent[]
  leaveRequests    LeaveRequest[] // M4: virtual back-relation only
  // + raw SQL: RLS ON — admin ALL; parent SELECT self (userId = auth.uid()) (people_rls, Step 4)

  @@index([schoolId])
}

// ---------- student ↔ parent (junction) ----------
// PK includes relationship: one person may hold multiple relationships to one
// child. Cascade from both parents/students (a link has no independent meaning).
model StudentParent {
  studentId    String
  parentId     String
  relationship StudentRelationship
  isPrimary    Boolean             @default(false)
  createdAt    DateTime            @default(now())
  student      Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent       Parent              @relation(fields: [parentId], references: [id], onDelete: Cascade)
  // + raw SQL: partial unique — one PRIMARY contact per student: WHERE "isPrimary"

  @@id([studentId, parentId, relationship])
  @@index([parentId])
  @@index([studentId])
}

// ---------- staff (employment profile; extends User 1:1) ----------
// No auth duplication — credentials/role/status stay on the frozen User. This is
// DESCRIPTIVE only: a teacher's read-scope derives from TeacherAssignment→Section,
// never from Staff. Named Staff (not TeacherProfile) for forward-consistency.
model Staff {
  id                   String                 @id @default(cuid())
  schoolId             String // loose tenant ref (ADR-008)
  userId               String                 @unique
  employeeId           String
  department           String?
  qualification        String?
  experienceYears      Int?
  joiningDate          DateTime?              @db.Date
  bio                  String?
  photoPath            String? // PRIVATE storage path, signed on read (ADR-004)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // M4: virtual back-relations only — attendance audit actors + correction actors (no DB change to this frozen M3 model)
  sessionsCreated      AttendanceSession[]    @relation("SessionCreatedBy")
  sessionsSubmitted    AttendanceSession[]    @relation("SessionSubmittedBy")
  sessionsLocked       AttendanceSession[]    @relation("SessionLockedBy")
  correctionsRequested AttendanceCorrection[] @relation("CorrectionRequestedBy")
  correctionsDecided   AttendanceCorrection[] @relation("CorrectionDecidedBy")
  leavesDecided        LeaveRequest[]
  // + raw SQL: RLS ON — admin ALL; staff SELECT self (userId = auth.uid()) (people_rls, Step 4)

  @@unique([schoolId, employeeId])
  @@index([schoolId])
}

// ---------- enrollment (per-year placement; ADR-010 is the source of truth) ----------
// One row per student per year. sectionId NULLABLE (ADMITTED before placement).
// classId is its OWN column (not derived from section) so it survives a null
// section and makes promotion/retention a clean field diff. All refs Restrict:
// enrollments carry (future) attendance/marks/fees and are never hard-deleted —
// lifecycle is via status. Section transfer = in-place sectionId update (audited).
// BUSINESS RULE: rollNo is assigned only after a student is allocated to a
// section — a rollNo without a sectionId is invalid. Enforced by a CHECK below
// (rollNo NULL OR sectionId NOT NULL) and by EnrollmentService on allocation.
model Enrollment {
  id                String             @id @default(cuid())
  schoolId          String // loose tenant ref (ADR-008)
  studentId         String
  academicYearId    String
  classId           String
  sectionId         String?
  rollNo            Int? // set only once sectionId is assigned (see CHECK below)
  status            EnrollmentStatus   @default(ADMITTED)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  student           Student            @relation(fields: [studentId], references: [id], onDelete: Restrict)
  academicYear      AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class             Class              @relation(fields: [classId], references: [id], onDelete: Restrict)
  section           Section?           @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  attendanceRecords AttendanceRecord[] // M4: virtual back-relation only
  leaveRequests     LeaveRequest[] // M4: virtual back-relation only
  // + raw SQL: partial unique — roll number unique per section per year:
  //   WHERE "sectionId" IS NOT NULL AND "rollNo" IS NOT NULL
  // + raw SQL: CHECK ("rollNo" IS NULL OR "sectionId" IS NOT NULL) — rollNo only after allocation
  // + raw SQL: RLS ON — admin ALL; teacher SELECT own-section; parent SELECT own-child (people_rls, Step 4)

  @@unique([studentId, academicYearId]) // one enrollment per student per year (ADR-010)
  @@index([academicYearId, sectionId]) // section roster this year
  @@index([academicYearId, classId]) // grade roster this year
  @@index([schoolId])
}

// ========================= Attendance Management (M4) =========================
// ADR-011 is the source of truth. Attendance keys to Enrollment, NEVER Student
// (history survives promotion by construction — ADR-010 §4/§8). A register is an
// AttendanceSession (the event) holding many AttendanceRecords (one mark per
// enrolled student). Ownership is DERIVED from TeacherAssignment — never stored
// on the session; the session persists only WHO ACTED (created/submitted/locked).
// All calendar dates are @db.Date (IST convention, no UTC off-by-one).

// ---------- enums ----------
// DAILY = whole-day register (subjectId null); SUBJECT = per-subject register
// (subjectId set). SUBJECT is modelled now for future period/subject attendance
// with no later migration — M4 UI is daily-first (ADR-011 §2, §4-of-analysis).
enum AttendanceSessionType {
  DAILY
  SUBJECT
}

// Register lifecycle. Forward-only, audited. DRAFT is the working state (no OPEN).
// After LOCKED the only path to change a record is the correction workflow.
enum AttendanceSessionStatus {
  DRAFT
  SUBMITTED
  LOCKED
}

// One status per (session, enrollment) — a single enum on one row makes the
// leave-vs-present contradiction (REVIEW_FINDINGS B2) structurally impossible.
// LATE = present-but-flagged (counts present); HALF_DAY = 0.5 in % rollups;
// LEAVE is a marking-time default from approved leave, never an eager write.
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HolidayType {
  NATIONAL
  SCHOOL
  FESTIVAL
  EMERGENCY_CLOSURE
}

// ---------- attendance session (the register event) ----------
// Uniqueness is TWO partial indexes (raw SQL) because Postgres treats NULLs as
// distinct — a plain unique on a nullable subjectId would let two DAILY sessions
// (both subjectId NULL) coexist for one section/date. Ownership is NOT stored:
// who-may-mark derives from TeacherAssignment at authz time (ADR-011 §3). The
// three *ByStaffId FKs are audit actors, not owners; all Restrict (a Staff row
// that acted on a register is never hard-deleted). Requires the actor to have a
// Staff row (REVIEW_FINDINGS B3 provisioning invariant).
model AttendanceSession {
  id                 String                  @id @default(cuid())
  schoolId           String // loose tenant ref (ADR-008)
  academicYearId     String
  sectionId          String
  subjectId          String? // null for DAILY; set for SUBJECT
  sessionType        AttendanceSessionType   @default(DAILY)
  date               DateTime                @db.Date
  status             AttendanceSessionStatus @default(DRAFT)
  createdByStaffId   String
  submittedByStaffId String? // stamped on DRAFT→SUBMITTED
  lockedByStaffId    String? // stamped on SUBMITTED→LOCKED
  submittedAt        DateTime?
  lockedAt           DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  academicYear       AcademicYear            @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  section            Section                 @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  subject            Subject?                @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  createdBy          Staff                   @relation("SessionCreatedBy", fields: [createdByStaffId], references: [id], onDelete: Restrict)
  submittedBy        Staff?                  @relation("SessionSubmittedBy", fields: [submittedByStaffId], references: [id], onDelete: Restrict)
  lockedBy           Staff?                  @relation("SessionLockedBy", fields: [lockedByStaffId], references: [id], onDelete: Restrict)
  records            AttendanceRecord[]
  // + raw SQL: partial unique — DAILY: one per section/date/type:
  //   UNIQUE ("sectionId","date","sessionType") WHERE "subjectId" IS NULL
  // + raw SQL: partial unique — SUBJECT: one per section/date/type/subject:
  //   UNIQUE ("sectionId","date","sessionType","subjectId") WHERE "subjectId" IS NOT NULL
  // + raw SQL: RLS ON — admin ALL; teacher own-assigned-section; parent none (attendance_rls, Step 4)

  @@index([sectionId, date]) // register lookup (hot path)
  @@index([academicYearId, date]) // calendar / reporting scan
  @@index([schoolId])
}

// ---------- attendance record (one student's mark within a session) ----------
// enrollmentId is the ONLY link to a student (ADR-011 §1) — no studentId column.
// Cascade from session (a session's records are its content); Restrict on
// enrollment (records outlive nothing — the enrollment carrying them is never
// hard-deleted). Unique (session, enrollment) => one mark per student per
// session; re-submit is an idempotent upsert (offline-safe), not a duplicate.
model AttendanceRecord {
  id           String                 @id @default(cuid())
  schoolId     String // loose tenant ref (ADR-008)
  sessionId    String
  enrollmentId String
  status       AttendanceStatus
  remarks      String? // optional per-mark note (e.g. "medical certificate received", "late — transport")
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  session      AttendanceSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enrollment   Enrollment             @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  corrections  AttendanceCorrection[]
  // + raw SQL: RLS ON — admin ALL; teacher own-assigned-section; parent own-child (attendance_rls, Step 4)

  @@unique([sessionId, enrollmentId]) // one mark per student per session
  @@index([enrollmentId]) // student attendance history (feeds report-card % — ADR-009)
  @@index([schoolId])
}

// ---------- leave request (parent-initiated absence) ----------
// Keyed to Enrollment (never Student). Approved leave does NOT write attendance
// rows — it only biases the DEFAULT mark when a session is processed (ADR-011 §7).
// Restrict on both FKs: a parent/enrollment with leave history is not hard-deleted.
model LeaveRequest {
  id               String      @id @default(cuid())
  schoolId         String // loose tenant ref (ADR-008)
  enrollmentId     String
  parentId         String
  fromDate         DateTime    @db.Date
  toDate           DateTime    @db.Date
  reason           String
  status           LeaveStatus @default(PENDING)
  decidedByStaffId String? // admin / class-teacher who approved/rejected
  decidedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  enrollment       Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  parent           Parent      @relation(fields: [parentId], references: [id], onDelete: Restrict)
  decidedBy        Staff?      @relation(fields: [decidedByStaffId], references: [id], onDelete: Restrict)
  // + raw SQL: CHECK ("fromDate" <= "toDate")
  // + raw SQL: RLS ON — admin ALL; parent own-child (via enrollment→student→parent); teacher own-section read (attendance_rls, Step 4)

  @@index([enrollmentId, status]) // marking-default lookup: approved leave covering a date
  @@index([parentId])
  @@index([schoolId])
}

// ---------- attendance correction (immutable request) ----------
// The request payload (record, previous/requested status, reason) is IMMUTABLE
// (ADR-011 §8) — a correction is a historical assertion, never edited/deleted.
// previous/requestedStatus are snapshots at request time. On APPROVE (one tx):
// AttendanceRecord.status := requestedStatus, this row := APPROVED, + AuditLog
// (ADR-007). The record is never overwritten silently. Only decision fields
// (status, decidedBy, decidedAt) transition — once. Cascade from record.
model AttendanceCorrection {
  id                 String           @id @default(cuid())
  schoolId           String // loose tenant ref (ADR-008)
  attendanceRecordId String
  requestedByStaffId String
  previousStatus     AttendanceStatus // snapshot at request time
  requestedStatus    AttendanceStatus // what the record should become
  reason             String
  status             CorrectionStatus @default(PENDING)
  decidedByStaffId   String?
  decidedAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  attendanceRecord   AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  requestedBy        Staff            @relation("CorrectionRequestedBy", fields: [requestedByStaffId], references: [id], onDelete: Restrict)
  decidedBy          Staff?           @relation("CorrectionDecidedBy", fields: [decidedByStaffId], references: [id], onDelete: Restrict)
  // + raw SQL: RLS ON — admin ALL; teacher own-assigned-section (attendance_rls, Step 4)

  @@index([attendanceRecordId])
  @@index([status])
  @@index([schoolId])
}

// ---------- holiday (working-day calendar; year-scoped) ----------
// Session creation consults a working-day resolution (baseline weekday − Holiday
// + future WorkingDayOverride), NOT a per-call override boolean (ADR-011 §9). The
// override layer is a designed-in extension point — NOT built in M4. Cascade from
// AcademicYear (year-owned config, like AcademicTerm).
model Holiday {
  id             String       @id @default(cuid())
  schoolId       String // loose tenant ref (ADR-008)
  academicYearId String
  name           String
  date           DateTime     @db.Date
  type           HolidayType
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  // + raw SQL: RLS ON — admin ALL; teacher/parent SELECT (read-only calendar) (attendance_rls, Step 4)

  @@unique([academicYearId, date]) // one holiday per calendar day per year
  @@index([schoolId])
}
