// Prisma schema — M1 (authentication foundation) + M2 (academic structure).
//
// M1: tenant root (School) + identity (User) + devices (DeviceToken) + audit
// (AuditLog) + auth enums. M2: AcademicYear/AcademicTerm (time axis) and
// Class/Section/Subject (structure axis) joined by TeacherAssignment.
// Students, enrollment, attendance, exams, people records land in later
// milestones per the M2 kickoff brief.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- enums ----------
enum Role {
  SUPER_ADMIN
  OFFICE_ADMIN
  TEACHER
  PARENT
  ACCOUNTANT
}

enum UserStatus {
  INVITED // provisioned, not yet signed in
  ACTIVE // activated on first successful sign-in
  DISABLED // soft-disabled; history preserved, access revoked
}

enum Locale {
  EN
  ML
}

// ---------- tenant ----------
// Single-tenant today. `schoolId` is a LOOSE scalar on other tables (ADR-008),
// so School has no back-relations; it is the tenant root the seed creates.
model School {
  id            String   @id @default(cuid())
  name          String
  address       String?
  logoUrl       String?
  defaultLocale Locale   @default(EN)
  settings      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  // + raw SQL: RLS ON — admin read only (m1_rls_hardening; defense-in-depth)
}

// ---------- identity (profile keyed to the Supabase auth UID) ----------
// `id` == Supabase `auth.users.id` — no separate PK, no default (the UID is
// supplied at provisioning). Credentials/OTP live in Supabase; we store none.
model User {
  id                      String                   @id
  schoolId                String // loose tenant ref (ADR-008)
  role                    Role
  status                  UserStatus               @default(INVITED)
  phone                   String?                  @unique
  email                   String?                  @unique
  locale                  Locale                   @default(EN)
  lastLoginAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deviceTokens            DeviceToken[]
  // Virtual back-relations only (no column/behavior change to the frozen M1 model).
  teacherAssignments      TeacherAssignment[]
  classTeacherAssignments ClassTeacherAssignment[] // M7 foundation: sections where this user is the class teacher (virtual back-relation only)
  staff                   Staff? // M3: employment profile, 1:1 (userId unique on Staff)
  parent                  Parent? // M3: parent portal login, 1:1 (userId unique on Parent)
  // + raw SQL: RLS ON — read-self + admin-read-all (m1_rls_hardening)

  @@index([schoolId, role])
}

// ---------- devices ----------
// Table designed in M1 (per the milestone's model list); device REGISTRATION and
// push delivery are deferred to the Notifications milestone (no registerDevice yet).
model DeviceToken {
  id            String   @id @default(cuid())
  userId        String
  expoPushToken String   @unique
  platform      String
  lastSeenAt    DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // + raw SQL: RLS ON — owner read only (m1_rls_hardening)

  @@index([userId])
}

// ---------- academic structure (M2) ----------

// Lifecycle of a year: PLANNED (setup) → ACTIVE (in session; exactly one per
// school, enforced by a partial unique index — raw SQL, ADR-009) → CLOSED
// (terminal; year + terms locked). Rollover flips old→CLOSED, new→ACTIVE in
// one transaction.
enum AcademicYearStatus {
  PLANNED
  ACTIVE
  CLOSED
}

// TIME axis root, e.g. "2026–27". Calendar dates are @db.Date (IST convention,
// Dev PRD decision #22) so range logic can't drift by a UTC off-by-one.
model AcademicYear {
  id                      String                   @id @default(cuid())
  schoolId                String // loose tenant ref (ADR-008)
  name                    String
  startDate               DateTime                 @db.Date
  endDate                 DateTime                 @db.Date
  status                  AcademicYearStatus       @default(PLANNED)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  terms                   AcademicTerm[]
  enrollments             Enrollment[] // M3: virtual back-relation only (no change to frozen M2 model)
  holidays                Holiday[] // M4: virtual back-relation only (no change to frozen M2 model)
  attendanceSessions      AttendanceSession[] // M4: virtual back-relation only
  exams                   Exam[] // M5: virtual back-relation only
  homework                Homework[] // M6: virtual back-relation only
  classTeacherAssignments ClassTeacherAssignment[] // M7 foundation: virtual back-relation only
  // + raw SQL: UNIQUE (schoolId) WHERE status = 'ACTIVE'  — one ACTIVE year
  // + raw SQL: CHECK (startDate < endDate)
  // + raw SQL: RLS ON — admin-only ALL (academic_rls migration; defense-in-depth)

  @@unique([schoolId, name])
  @@index([schoolId, status])
}

// Subdivision of a year, e.g. "Term 1". Sibling terms must not overlap
// (inclusive dates) — enforced by an EXCLUDE USING gist constraint (raw SQL)
// plus the business-layer check; ordering derives from startDate.
model AcademicTerm {
  id             String       @id @default(cuid())
  academicYearId String
  name           String
  startDate      DateTime     @db.Date
  endDate        DateTime     @db.Date
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  reportCards    ReportCard[] // M7: virtual back-relation only (TERM-card scope; ADR-014)
  // + raw SQL: EXCLUDE USING gist (academicYearId =, daterange(start,end,'[]') &&)
  // + raw SQL: CHECK (startDate < endDate)
  // + raw SQL: RLS ON — admin-only ALL (academic_rls migration)

  @@unique([academicYearId, name])
  @@index([academicYearId, startDate])
}

// STRUCTURE axis: a grade level ("Grade 5"). Persistent across years —
// enrollment (M3) binds student × section × year. sortOrder gives deterministic
// display order ("Grade 10" would otherwise sort before "Grade 2").
model Class {
  id          String       @id @default(cuid())
  schoolId    String // loose tenant ref (ADR-008)
  name        String
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  sections    Section[]
  enrollments Enrollment[] // M3: virtual back-relation only (no change to frozen M2 model)
  // + raw SQL: RLS ON — admin-only ALL (academic_rls migration)

  @@unique([schoolId, name])
  @@index([schoolId, sortOrder])
}

// Parallel group within a class ("A", "B"). Restrict delete from Class: a class
// with sections must be emptied deliberately (no cascade data loss).
model Section {
  id                      String                   @id @default(cuid())
  classId                 String
  name                    String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  class                   Class                    @relation(fields: [classId], references: [id], onDelete: Restrict)
  teacherAssignments      TeacherAssignment[]
  enrollments             Enrollment[] // M3: virtual back-relation only (no change to frozen M2 model)
  attendanceSessions      AttendanceSession[] // M4: virtual back-relation only
  examSections            ExamSection[] // M5: virtual back-relation only
  homework                Homework[] // M6: virtual back-relation only
  classTeacherAssignments ClassTeacherAssignment[] // M7 foundation: virtual back-relation only
  // + raw SQL: RLS ON — admin-only ALL (academic_rls migration)

  @@unique([classId, name])
}

// School-wide subject catalog ("Gujarati", "Mathematics") — a sibling of the
// Class tree, meeting sections only through TeacherAssignment.
model Subject {
  id                 String              @id @default(cuid())
  schoolId           String // loose tenant ref (ADR-008)
  name               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  teacherAssignments TeacherAssignment[]
  attendanceSessions AttendanceSession[] // M4: virtual back-relation only
  assessments        Assessment[] // M5: virtual back-relation only
  homework           Homework[] // M6: virtual back-relation only
  // + raw SQL: RLS ON — admin-only ALL (academic_rls migration)

  @@unique([schoolId, name])
}

// The operational unit: teacher × subject × section. teacherId references
// User directly (no Staff table in M2); the role/status check is business-layer.
// Immutable — no update; staffing changes are audited delete + create. NOT
// year-scoped per the M2 brief (unique triple below); year scoping is an
// additive migration if a later milestone needs assignment history.
// A class-teacher is NOT a flag on this table (a teacher teaching 3 subjects in a
// section would need 3 flagged rows, and a class teacher may teach NO subject in
// their section) — it is the dedicated year-scoped `ClassTeacherAssignment` below
// (M7 foundation). This model stays exactly as frozen in M2.
model TeacherAssignment {
  id        String   @id @default(cuid())
  schoolId  String // denormalized loose tenant ref — scope queries + audit (ADR-008)
  teacherId String
  subjectId String
  sectionId String
  createdAt DateTime @default(now())
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  // + raw SQL: RLS ON — admin ALL + teacher SELECT own (teacherId = auth.uid())

  @@unique([teacherId, subjectId, sectionId])
  @@index([sectionId])
  @@index([subjectId])
  @@index([schoolId])
}

// ---------- audit (append-only) ----------
// Loose actor/entity refs on purpose — append-only history that outlives the rows
// it describes; entityType+entityId is polymorphic (ADR-007). Written by services
// for role/user changes (setRole, disableUser) in the same transaction.
model AuditLog {
  id          String   @id @default(cuid())
  schoolId    String
  actorUserId String
  action      String
  entityType  String
  entityId    String
  beforeJson  Json?
  afterJson   Json?
  createdAt   DateTime @default(now())
  // + raw SQL: RLS ON — admin read only (m1_rls_hardening)

  @@index([entityType, entityId])
  @@index([schoolId, createdAt])
}

// ========================= People Management (M3) =========================
// Student = IDENTITY ONLY (no class/section/year). Enrollment owns per-year
// placement (ADR-010). Two lifecycle axes kept separate: Student.status (the
// person) vs EnrollmentStatus (the year's placement). Names diverge from the
// DEV_PRD deliberately (Parent not Guardian) — approved M3 decision.

// ---------- enums ----------
enum Gender {
  MALE
  FEMALE
  OTHER
}

// Person-level lifecycle. Distinct from EnrollmentStatus. No soft-delete column
// (DATABASE_CONVENTIONS §3) — ARCHIVED/WITHDRAWN/GRADUATED carry the reason.
enum StudentStatus {
  ACTIVE
  ARCHIVED
  GRADUATED
  WITHDRAWN
}

// Per-(student,parent) relationship — lives on the junction so one person can be
// FATHER to one child and GUARDIAN/EMERGENCY_CONTACT to another.
enum StudentRelationship {
  FATHER
  MOTHER
  GUARDIAN
  EMERGENCY_CONTACT
}

enum PreferredContact {
  PHONE
  EMAIL
  WHATSAPP
}

// DOCUMENT VISIBILITY (business-layer authorization; RLS is unchanged and only
// governs WHO reaches a student's docs). StudentDocumentService filters WHICH
// types are returned by role:
//   TEACHER            → PHOTO only (all other types hidden)
//   PARENT (own child) → all types
//   OFFICE_ADMIN / SUPER_ADMIN → all types
// Never expose MEDICAL_RECORD to teachers — if teachers ever need medical info,
// add a dedicated Medical Summary feature, not access to the uploaded files.
enum StudentDocumentType {
  BIRTH_CERTIFICATE
  PASSPORT
  AADHAAR
  MEDICAL_RECORD
  TRANSFER_CERTIFICATE
  PHOTO // the ONLY teacher-visible type
  OTHER
}

// Year-placement lifecycle (ADR-010). ADMITTED → ACTIVE → one terminal state.
enum EnrollmentStatus {
  ADMITTED
  ACTIVE
  PROMOTED
  RETAINED
  TRANSFERRED
  DROPPED
  ALUMNI
}

// ---------- student (identity) ----------
// admissionNo unique per school; calendar dob is @db.Date (IST convention, no
// UTC off-by-one). photoPath is a PRIVATE storage path signed on read (ADR-004).
model Student {
  id          String            @id @default(cuid())
  schoolId    String // loose tenant ref (ADR-008)
  admissionNo String
  firstName   String
  lastName    String
  dob         DateTime?         @db.Date
  gender      Gender?
  bloodGroup  String?
  nationality String?
  aadhaar     String? // optional national ID; sensitive — unique per school when present (raw SQL below)
  passport    String?
  address     String?
  photoPath   String? // PRIVATE storage path, signed on read (ADR-004)
  status      StudentStatus     @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  enrollments Enrollment[]
  parents     StudentParent[]
  documents   StudentDocument[]
  // + raw SQL: partial unique — Aadhaar unique per school when present:
  //   WHERE "aadhaar" IS NOT NULL  (a shared national ID is a data error)
  // + raw SQL: RLS ON — admin ALL; teacher SELECT own-section; parent SELECT own-child (people_rls, Step 4)

  @@unique([schoolId, admissionNo])
  @@index([schoolId, status])
  @@index([schoolId, lastName, firstName]) // roster search/sort
}

// ---------- student documents (metadata; bytes live in Supabase Storage) ----------
// version is versioning-ready: replace bumps version (no unique on (student,type),
// so historical versions coexist — full history table is a later concern).
// Retrieval = storagePath (signed on read). Validation = mimeType + sizeBytes +
// optional checksum (SHA-256 hex; integrity check on download). uploadedAt is
// `createdAt` — the row is written at upload time.
model StudentDocument {
  id               String              @id @default(cuid())
  schoolId         String // loose tenant ref (ADR-008)
  studentId        String
  type             StudentDocumentType
  storagePath      String // PRIVATE bucket path (ADR-004), signed on read
  fileName         String
  mimeType         String?
  sizeBytes        Int?
  checksum         String? // optional SHA-256 hex — verify integrity on download
  version          Int                 @default(1)
  uploadedByUserId String // actor (loose ref — append-only-ish metadata)
  createdAt        DateTime            @default(now()) // == uploadedAt
  student          Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  // + raw SQL: RLS ON — mirrors Student visibility (people_rls, Step 4)

  @@index([studentId, type])
  @@index([schoolId])
}

// ---------- parent (contact / guardian) ----------
// userId NULLABLE: an app-login parent (Role=PARENT) carries the Supabase uid for
// RLS parent-scope; an emergency-only contact has null uid and no portal access.
// SetNull (not Cascade): removing the login keeps the contact record.
model Parent {
  id                    String                 @id @default(cuid())
  schoolId              String // loose tenant ref (ADR-008)
  userId                String?                @unique
  name                  String
  phone                 String
  email                 String?
  occupation            String?
  address               String?
  preferredContact      PreferredContact       @default(PHONE)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  students              StudentParent[]
  leaveRequests         LeaveRequest[] // M4: virtual back-relation only
  // M6: virtual back-relations only — submission + upload actors (parents submit for children)
  homeworkSubmissions   HomeworkSubmission[]
  submissionAttachments SubmissionAttachment[]
  // + raw SQL: RLS ON — admin ALL; parent SELECT self (userId = auth.uid()) (people_rls, Step 4)

  @@index([schoolId])
}

// ---------- student ↔ parent (junction) ----------
// PK includes relationship: one person may hold multiple relationships to one
// child. Cascade from both parents/students (a link has no independent meaning).
model StudentParent {
  studentId    String
  parentId     String
  relationship StudentRelationship
  isPrimary    Boolean             @default(false)
  createdAt    DateTime            @default(now())
  student      Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent       Parent              @relation(fields: [parentId], references: [id], onDelete: Cascade)
  // + raw SQL: partial unique — one PRIMARY contact per student: WHERE "isPrimary"

  @@id([studentId, parentId, relationship])
  @@index([parentId])
  @@index([studentId])
}

// ---------- staff (employment profile; extends User 1:1) ----------
// No auth duplication — credentials/role/status stay on the frozen User. This is
// DESCRIPTIVE only: a teacher's read-scope derives from TeacherAssignment→Section,
// never from Staff. Named Staff (not TeacherProfile) for forward-consistency.
model Staff {
  id                          String                   @id @default(cuid())
  schoolId                    String // loose tenant ref (ADR-008)
  userId                      String                   @unique
  name                        String // display name — one field, Indian-name-friendly (ADR-016); backfilled then NOT NULL
  employeeId                  String
  department                  String?
  qualification               String?
  experienceYears             Int?
  joiningDate                 DateTime?                @db.Date
  bio                         String?
  photoPath                   String? // PRIVATE storage path, signed on read (ADR-004)
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
  user                        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // M4: virtual back-relations only — attendance audit actors + correction actors (no DB change to this frozen M3 model)
  sessionsCreated             AttendanceSession[]      @relation("SessionCreatedBy")
  sessionsSubmitted           AttendanceSession[]      @relation("SessionSubmittedBy")
  sessionsLocked              AttendanceSession[]      @relation("SessionLockedBy")
  correctionsRequested        AttendanceCorrection[]   @relation("CorrectionRequestedBy")
  correctionsDecided          AttendanceCorrection[]   @relation("CorrectionDecidedBy")
  leavesDecided               LeaveRequest[]
  // M5: virtual back-relations only — exam publish + exam-section audit actors + mark entry
  examsPublished              Exam[]                   @relation("ExamPublishedBy")
  examSectionsCreated         ExamSection[]            @relation("ExamSectionCreatedBy")
  examSectionsSubmitted       ExamSection[]            @relation("ExamSectionSubmittedBy")
  examSectionsLocked          ExamSection[]            @relation("ExamSectionLockedBy")
  examSectionsUnlocked        ExamSection[]            @relation("ExamSectionUnlockedBy")
  marksEntered                Mark[]                   @relation("MarkEnteredBy")
  // M6: virtual back-relations only — homework lifecycle + review audit actors
  homeworkCreated             Homework[]               @relation("HomeworkCreatedBy")
  homeworkPublished           Homework[]               @relation("HomeworkPublishedBy")
  homeworkClosed              Homework[]               @relation("HomeworkClosedBy")
  homeworkReopened            Homework[]               @relation("HomeworkReopenedBy")
  homeworkAttachmentsUploaded HomeworkAttachment[]     @relation("HomeworkAttachmentUploadedBy")
  submissionsReviewed         HomeworkSubmission[]     @relation("SubmissionReviewedBy")
  homeworkFeedbackAuthored    HomeworkFeedback[]       @relation("HomeworkFeedbackAuthor")
  // M6.5: virtual back-relation only — class-teacher assignments this staff performed (audit actor)
  classTeacherAssignmentsMade ClassTeacherAssignment[] @relation("ClassTeacherAssignedBy")
  // M7: virtual back-relations only — report-card lifecycle audit actors (B3)
  reportCardsCreated          ReportCard[]             @relation("ReportCardCreatedBy")
  reportCardsSubmitted        ReportCard[]             @relation("ReportCardSubmittedBy")
  reportCardsApproved         ReportCard[]             @relation("ReportCardApprovedBy")
  reportCardsPublished        ReportCard[]             @relation("ReportCardPublishedBy")
  reportCardsReopened         ReportCard[]             @relation("ReportCardReopenedBy")
  reportCardsRevoked          ReportCard[]             @relation("ReportCardRevokedBy")
  // + raw SQL: RLS ON — admin ALL; staff SELECT self (userId = auth.uid()) (people_rls, Step 4)

  @@unique([schoolId, employeeId])
  @@index([schoolId])
}

// ---------- enrollment (per-year placement; ADR-010 is the source of truth) ----------
// One row per student per year. sectionId NULLABLE (ADMITTED before placement).
// classId is its OWN column (not derived from section) so it survives a null
// section and makes promotion/retention a clean field diff. All refs Restrict:
// enrollments carry (future) attendance/marks/fees and are never hard-deleted —
// lifecycle is via status. Section transfer = in-place sectionId update (audited).
// BUSINESS RULE: rollNo is assigned only after a student is allocated to a
// section — a rollNo without a sectionId is invalid. Enforced by a CHECK below
// (rollNo NULL OR sectionId NOT NULL) and by EnrollmentService on allocation.
model Enrollment {
  id                  String               @id @default(cuid())
  schoolId            String // loose tenant ref (ADR-008)
  studentId           String
  academicYearId      String
  classId             String
  sectionId           String?
  rollNo              Int? // set only once sectionId is assigned (see CHECK below)
  status              EnrollmentStatus     @default(ADMITTED)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  student             Student              @relation(fields: [studentId], references: [id], onDelete: Restrict)
  academicYear        AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class               Class                @relation(fields: [classId], references: [id], onDelete: Restrict)
  section             Section?             @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  attendanceRecords   AttendanceRecord[] // M4: virtual back-relation only
  leaveRequests       LeaveRequest[] // M4: virtual back-relation only
  marks               Mark[] // M5: virtual back-relation only
  homeworkSubmissions HomeworkSubmission[] // M6: virtual back-relation only
  reportCards         ReportCard[] // M7: virtual back-relation only (owner side; ADR-014)
  // + raw SQL: partial unique — roll number unique per section per year:
  //   WHERE "sectionId" IS NOT NULL AND "rollNo" IS NOT NULL
  // + raw SQL: CHECK ("rollNo" IS NULL OR "sectionId" IS NOT NULL) — rollNo only after allocation
  // + raw SQL: RLS ON — admin ALL; teacher SELECT own-section; parent SELECT own-child (people_rls, Step 4)

  @@unique([studentId, academicYearId]) // one enrollment per student per year (ADR-010)
  @@index([academicYearId, sectionId]) // section roster this year
  @@index([academicYearId, classId]) // grade roster this year
  @@index([schoolId])
}

// ========================= Attendance Management (M4) =========================
// ADR-011 is the source of truth. Attendance keys to Enrollment, NEVER Student
// (history survives promotion by construction — ADR-010 §4/§8). A register is an
// AttendanceSession (the event) holding many AttendanceRecords (one mark per
// enrolled student). Ownership is DERIVED from TeacherAssignment — never stored
// on the session; the session persists only WHO ACTED (created/submitted/locked).
// All calendar dates are @db.Date (IST convention, no UTC off-by-one).

// ---------- enums ----------
// DAILY = whole-day register (subjectId null); SUBJECT = per-subject register
// (subjectId set). SUBJECT is modelled now for future period/subject attendance
// with no later migration — M4 UI is daily-first (ADR-011 §2, §4-of-analysis).
enum AttendanceSessionType {
  DAILY
  SUBJECT
}

// Register lifecycle. Forward-only, audited. DRAFT is the working state (no OPEN).
// After LOCKED the only path to change a record is the correction workflow.
enum AttendanceSessionStatus {
  DRAFT
  SUBMITTED
  LOCKED
}

// One status per (session, enrollment) — a single enum on one row makes the
// leave-vs-present contradiction (REVIEW_FINDINGS B2) structurally impossible.
// LATE = present-but-flagged (counts present); HALF_DAY = 0.5 in % rollups;
// LEAVE is a marking-time default from approved leave, never an eager write.
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HolidayType {
  NATIONAL
  SCHOOL
  FESTIVAL
  EMERGENCY_CLOSURE
}

// ---------- attendance session (the register event) ----------
// Uniqueness is TWO partial indexes (raw SQL) because Postgres treats NULLs as
// distinct — a plain unique on a nullable subjectId would let two DAILY sessions
// (both subjectId NULL) coexist for one section/date. Ownership is NOT stored:
// who-may-mark derives from TeacherAssignment at authz time (ADR-011 §3). The
// three *ByStaffId FKs are audit actors, not owners; all Restrict (a Staff row
// that acted on a register is never hard-deleted). Requires the actor to have a
// Staff row (REVIEW_FINDINGS B3 provisioning invariant).
model AttendanceSession {
  id                 String                  @id @default(cuid())
  schoolId           String // loose tenant ref (ADR-008)
  academicYearId     String
  sectionId          String
  subjectId          String? // null for DAILY; set for SUBJECT
  sessionType        AttendanceSessionType   @default(DAILY)
  date               DateTime                @db.Date
  status             AttendanceSessionStatus @default(DRAFT)
  createdByStaffId   String
  submittedByStaffId String? // stamped on DRAFT→SUBMITTED
  lockedByStaffId    String? // stamped on SUBMITTED→LOCKED
  submittedAt        DateTime?
  lockedAt           DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  academicYear       AcademicYear            @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  section            Section                 @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  subject            Subject?                @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  createdBy          Staff                   @relation("SessionCreatedBy", fields: [createdByStaffId], references: [id], onDelete: Restrict)
  submittedBy        Staff?                  @relation("SessionSubmittedBy", fields: [submittedByStaffId], references: [id], onDelete: Restrict)
  lockedBy           Staff?                  @relation("SessionLockedBy", fields: [lockedByStaffId], references: [id], onDelete: Restrict)
  records            AttendanceRecord[]
  // + raw SQL: partial unique — DAILY: one per section/date/type:
  //   UNIQUE ("sectionId","date","sessionType") WHERE "subjectId" IS NULL
  // + raw SQL: partial unique — SUBJECT: one per section/date/type/subject:
  //   UNIQUE ("sectionId","date","sessionType","subjectId") WHERE "subjectId" IS NOT NULL
  // + raw SQL: RLS ON — admin ALL; teacher own-assigned-section; parent none (attendance_rls, Step 4)

  @@index([sectionId, date]) // register lookup (hot path)
  @@index([academicYearId, date]) // calendar / reporting scan
  @@index([schoolId])
}

// ---------- attendance record (one student's mark within a session) ----------
// enrollmentId is the ONLY link to a student (ADR-011 §1) — no studentId column.
// Cascade from session (a session's records are its content); Restrict on
// enrollment (records outlive nothing — the enrollment carrying them is never
// hard-deleted). Unique (session, enrollment) => one mark per student per
// session; re-submit is an idempotent upsert (offline-safe), not a duplicate.
model AttendanceRecord {
  id           String                 @id @default(cuid())
  schoolId     String // loose tenant ref (ADR-008)
  sessionId    String
  enrollmentId String
  status       AttendanceStatus
  remarks      String? // optional per-mark note (e.g. "medical certificate received", "late — transport")
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  session      AttendanceSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enrollment   Enrollment             @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  corrections  AttendanceCorrection[]
  // + raw SQL: RLS ON — admin ALL; teacher own-assigned-section; parent own-child (attendance_rls, Step 4)

  @@unique([sessionId, enrollmentId]) // one mark per student per session
  @@index([enrollmentId]) // student attendance history (feeds report-card % — ADR-009)
  @@index([schoolId])
}

// ---------- leave request (parent-initiated absence) ----------
// Keyed to Enrollment (never Student). Approved leave does NOT write attendance
// rows — it only biases the DEFAULT mark when a session is processed (ADR-011 §7).
// Restrict on both FKs: a parent/enrollment with leave history is not hard-deleted.
model LeaveRequest {
  id               String      @id @default(cuid())
  schoolId         String // loose tenant ref (ADR-008)
  enrollmentId     String
  parentId         String
  fromDate         DateTime    @db.Date
  toDate           DateTime    @db.Date
  reason           String
  status           LeaveStatus @default(PENDING)
  decidedByStaffId String? // admin / class-teacher who approved/rejected
  decidedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  enrollment       Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  parent           Parent      @relation(fields: [parentId], references: [id], onDelete: Restrict)
  decidedBy        Staff?      @relation(fields: [decidedByStaffId], references: [id], onDelete: Restrict)
  // + raw SQL: CHECK ("fromDate" <= "toDate")
  // + raw SQL: RLS ON — admin ALL; parent own-child (via enrollment→student→parent); teacher own-section read (attendance_rls, Step 4)

  @@index([enrollmentId, status]) // marking-default lookup: approved leave covering a date
  @@index([parentId])
  @@index([schoolId])
}

// ---------- attendance correction (immutable request) ----------
// The request payload (record, previous/requested status, reason) is IMMUTABLE
// (ADR-011 §8) — a correction is a historical assertion, never edited/deleted.
// previous/requestedStatus are snapshots at request time. On APPROVE (one tx):
// AttendanceRecord.status := requestedStatus, this row := APPROVED, + AuditLog
// (ADR-007). The record is never overwritten silently. Only decision fields
// (status, decidedBy, decidedAt) transition — once. Cascade from record.
model AttendanceCorrection {
  id                 String           @id @default(cuid())
  schoolId           String // loose tenant ref (ADR-008)
  attendanceRecordId String
  requestedByStaffId String
  previousStatus     AttendanceStatus // snapshot at request time
  requestedStatus    AttendanceStatus // what the record should become
  reason             String
  status             CorrectionStatus @default(PENDING)
  decidedByStaffId   String?
  decidedAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  attendanceRecord   AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  requestedBy        Staff            @relation("CorrectionRequestedBy", fields: [requestedByStaffId], references: [id], onDelete: Restrict)
  decidedBy          Staff?           @relation("CorrectionDecidedBy", fields: [decidedByStaffId], references: [id], onDelete: Restrict)
  // + raw SQL: RLS ON — admin ALL; teacher own-assigned-section (attendance_rls, Step 4)

  @@index([attendanceRecordId])
  @@index([status])
  @@index([schoolId])
}

// ---------- holiday (working-day calendar; year-scoped) ----------
// Session creation consults a working-day resolution (baseline weekday − Holiday
// + future WorkingDayOverride), NOT a per-call override boolean (ADR-011 §9). The
// override layer is a designed-in extension point — NOT built in M4. Cascade from
// AcademicYear (year-owned config, like AcademicTerm).
model Holiday {
  id             String       @id @default(cuid())
  schoolId       String // loose tenant ref (ADR-008)
  academicYearId String
  name           String
  date           DateTime     @db.Date
  type           HolidayType
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  // + raw SQL: RLS ON — admin ALL; teacher/parent SELECT (read-only calendar) (attendance_rls, Step 4)

  @@unique([academicYearId, date]) // one holiday per calendar day per year
  @@index([schoolId])
}

// ========================= Examination & Assessment (M5) =========================
// ADR-012 is the source of truth (extends ADR-011's register pattern). Marks key
// to Enrollment, NEVER Student (ADR-010 §8) so GPA/CGPA aggregate across years.
// Grain: Exam (event) → Assessment (Exam × Subject, the definition) → ExamSection
// (Assessment × Section, the REGISTER holding lifecycle + derived ownership; the
// AttendanceSession analog) → Mark (per Enrollment; the AttendanceRecord analog +
// an immutable result snapshot). Ownership is DERIVED from TeacherAssignment,
// never stored; ExamSection persists only WHO ACTED (created/submitted/locked/
// unlocked). Two axes: LOCK per ExamSection (immutability), PUBLISH per Exam
// (parent visibility). All dates @db.Date (IST, no UTC off-by-one).

// ---------- enums ----------
// Explicit exam kinds (ADR-012 §5, replaces the PRD's generic `category String`).
// CUSTOM is the open escape hatch so a new exam kind needs no migration.
enum ExamType {
  UNIT_TEST
  MONTHLY
  MID_TERM
  HALF_YEARLY
  MODEL
  ANNUAL
  PRACTICAL
  CUSTOM
}

// Register lifecycle — forward-only, audited, identical shape to
// AttendanceSessionStatus. LOCKED marks change only via the audited unlock
// workflow (ADR-012 §8); there is no MarkCorrection entity.
enum ExamSectionStatus {
  DRAFT
  SUBMITTED
  LOCKED
}

// ---------- exam (the event; owns publication) ----------
// School + AcademicYear scoped. Publication is an EXAM-level concern (ADR-012 §2):
// exam.publish exposes every LOCKED ExamSection beneath it at once — parents never
// see a partially-published exam. LOCK stays per ExamSection. gradeScaleId is
// nullable: the grade service resolves it, else the school's default GradeScale;
// LOCK hard-requires a resolvable scale (a grade cannot be snapshotted without one).
model Exam {
  id                 String       @id @default(cuid())
  schoolId           String // loose tenant ref (ADR-008)
  academicYearId     String
  gradeScaleId       String? // null → fall back to the school's isDefault scale at compute time
  name               String
  type               ExamType
  displayOrder       Int          @default(0) // UI order — never alphabetical (ADR-012 §6)
  startDate          DateTime?    @db.Date
  endDate            DateTime?    @db.Date
  isPublished        Boolean      @default(false)
  publishedAt        DateTime? // stamped on publish
  publishedByStaffId String? // WHO published (audit actor, not an owner)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  academicYear       AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  gradeScale         GradeScale?  @relation(fields: [gradeScaleId], references: [id], onDelete: Restrict)
  publishedBy        Staff?       @relation("ExamPublishedBy", fields: [publishedByStaffId], references: [id], onDelete: Restrict)
  assessments        Assessment[]
  reportCards        ReportCard[] // M7: virtual back-relation only (EXAM-card scope; ADR-014)
  // + raw SQL: RLS ON — admin ALL; teacher SELECT (own-assigned via assessment→section); parent SELECT published (exam_rls, Step 4)

  @@unique([academicYearId, name]) // one exam name per year
  @@index([schoolId])
  @@index([academicYearId, displayOrder]) // ordered exam list for a year
}

// ---------- assessment (Exam × Subject — the paper definition) ----------
// Uses Subject DIRECTLY (ADR-012 §3 — no ClassSubject, which was never built).
// School/year-wide: a subject's max marks don't vary by section. maxPractical is
// NULLABLE (ADR-012 §7) — a null means "theory-only", distinct from a practical
// worth zero. Cross-year consistency (Assessment's exam ↔ marks' enrollments) is a
// SERVICE invariant at the enrollment boundary (ADR-012 §10) — Subject is
// year-agnostic so it cannot be a FK. Cascade from Exam: deleting an (unpublished,
// unlocked) exam definition removes its assessments; published/locked deletion is
// blocked at the business layer, not by onDelete (ADR-012 risk R3, Step 3/5).
model Assessment {
  id           String        @id @default(cuid())
  schoolId     String // loose tenant ref (ADR-008)
  examId       String
  subjectId    String
  maxTheory    Int
  maxPractical Int? // null = theory-only (ADR-012 §7); denominator uses maxTheory + COALESCE(maxPractical,0)
  passMark     Int
  displayOrder Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  exam         Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject      Subject       @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  examSections ExamSection[]
  marks        Mark[]
  // + raw SQL: CHECK ("maxTheory" >= 0 AND ("maxPractical" IS NULL OR "maxPractical" >= 0)
  //            AND "passMark" >= 0 AND "passMark" <= "maxTheory" + COALESCE("maxPractical", 0))
  // + raw SQL: RLS ON — admin ALL; teacher SELECT own-assigned-subject; parent SELECT published (exam_rls, Step 4)

  @@unique([examId, subjectId]) // a subject appears once per exam
  @@index([subjectId])
  @@index([schoolId])
}

// ---------- exam section (Assessment × Section — THE REGISTER) ----------
// Direct analog of AttendanceSession: it holds the DRAFT→SUBMITTED→LOCKED
// lifecycle + WHO ACTED, and ownership DERIVES from TeacherAssignment(teacher,
// subject, section) at authz time (ADR-012 §9) — never stored. Unlock is an
// audited workflow (unlockedBy/At/Reason + AuditLog); it re-opens a LOCKED
// register so marks can be corrected, then re-locked (ADR-012 §8). All *ByStaffId
// are audit actors, all Restrict; the actor needs a Staff row (B3 invariant).
model ExamSection {
  id                 String            @id @default(cuid())
  schoolId           String // loose tenant ref (ADR-008)
  assessmentId       String
  sectionId          String
  status             ExamSectionStatus @default(DRAFT)
  createdByStaffId   String
  submittedByStaffId String? // stamped on DRAFT→SUBMITTED
  lockedByStaffId    String? // stamped on SUBMITTED→LOCKED
  submittedAt        DateTime?
  lockedAt           DateTime?
  unlockedByStaffId  String? // stamped on the audited unlock (LOCKED→DRAFT)
  unlockedAt         DateTime?
  unlockReason       String? // required by the service on unlock (ADR-012 §8)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  assessment         Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  section            Section           @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  createdBy          Staff             @relation("ExamSectionCreatedBy", fields: [createdByStaffId], references: [id], onDelete: Restrict)
  submittedBy        Staff?            @relation("ExamSectionSubmittedBy", fields: [submittedByStaffId], references: [id], onDelete: Restrict)
  lockedBy           Staff?            @relation("ExamSectionLockedBy", fields: [lockedByStaffId], references: [id], onDelete: Restrict)
  unlockedBy         Staff?            @relation("ExamSectionUnlockedBy", fields: [unlockedByStaffId], references: [id], onDelete: Restrict)
  marks              Mark[]
  // + raw SQL: RLS ON — admin ALL; teacher own-assigned-section; parent none (exam_rls, Step 4)

  @@unique([assessmentId, sectionId]) // one register per assessment per section
  @@index([sectionId])
  @@index([status])
  @@index([schoolId])
}

// ---------- mark (one student's result within a register) ----------
// enrollmentId is the ONLY link to a student (ADR-010 §8) — no studentId column;
// this is what lets GPA aggregate one enrollment and CGPA aggregate a student's
// enrollments across years. Carries BOTH examSectionId (register/lifecycle owner,
// Cascade — lock/unlock finds its marks here) AND a denormalized assessmentId: the
// natural key is (assessment, enrollment), which stays correct across a mid-year
// section transfer where (examSection, enrollment) would not (dual-FK idiom, ADR-010
// §3). theoryObtained/practicalObtained/isAbsent are editable in DRAFT; the SNAPSHOT
// fields (totalObtained, percentage, gradeBand*, grade*Snapshot) are computed and
// frozen at LOCK so a later GradeScale edit can never mutate a settled result
// (ADR-012 §3-4). gradeBandId is SetNull (provenance only — the letter/point
// snapshots are the source of truth, so a band may be reorganized/deleted).
model Mark {
  id                  String      @id @default(cuid())
  schoolId            String // loose tenant ref (ADR-008)
  examSectionId       String
  assessmentId        String // denormalized natural key (= examSection.assessmentId; service invariant)
  enrollmentId        String
  theoryObtained      Float? // editable in DRAFT
  practicalObtained   Float? // editable in DRAFT; null when the assessment is theory-only
  isAbsent            Boolean     @default(false)
  totalObtained       Float? // snapshot @lock — stored for read-convenience (= theory+practical)
  percentage          Float? // snapshot @lock — immutability-critical (depends on Assessment max marks)
  gradeBandId         String? // snapshot @lock — provenance FK (SetNull); letter/point below are authoritative
  gradeLetterSnapshot String? // snapshot @lock — the frozen grade letter (e.g. "A+")
  gradePointSnapshot  Float? // snapshot @lock — nullable (scale may omit points → GPA "not available")
  enteredByStaffId    String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  examSection         ExamSection @relation(fields: [examSectionId], references: [id], onDelete: Cascade)
  assessment          Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  enrollment          Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  gradeBand           GradeBand?  @relation(fields: [gradeBandId], references: [id], onDelete: SetNull)
  enteredBy           Staff       @relation("MarkEnteredBy", fields: [enteredByStaffId], references: [id], onDelete: Restrict)
  // + raw SQL: CHECK ("theoryObtained" IS NULL OR "theoryObtained" >= 0)
  // + raw SQL: CHECK ("practicalObtained" IS NULL OR "practicalObtained" >= 0)
  // + raw SQL: CHECK ("percentage" IS NULL OR ("percentage" >= 0 AND "percentage" <= 100))
  // + raw SQL: CHECK (NOT "isAbsent" OR ("theoryObtained" IS NULL AND "practicalObtained" IS NULL))
  //            — an absent mark carries no obtained marks (structural, like M4's single-status enum)
  // + raw SQL: RLS ON — admin ALL; teacher own-assigned-section; parent own-child PUBLISHED (exam_rls, Step 4)

  @@unique([assessmentId, enrollmentId]) // one mark per student per assessment (ADR-012 §1, transfer-safe)
  @@index([examSectionId]) // register roster (hot path: marks grid for one section)
  @@index([enrollmentId]) // student's marks — GPA/CGPA + future report card (ADR-009)
  @@index([schoolId])
}

// ---------- grade scale + bands (configurable A+→E; ADR-012 §3) ----------
// School-scoped catalog. Exactly one default per school (partial unique, mirrors
// the ACTIVE-year idiom) so the Exam.gradeScaleId fallback is deterministic.
model GradeScale {
  id        String      @id @default(cuid())
  schoolId  String // loose tenant ref (ADR-008)
  name      String
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  bands     GradeBand[]
  exams     Exam[]
  // + raw SQL: partial unique — one default per school:  UNIQUE ("schoolId") WHERE "isDefault"
  // + raw SQL: RLS ON — admin ALL; teacher/parent SELECT (read-only, grades reference it) (exam_rls, Step 4)

  @@unique([schoolId, name])
  @@index([schoolId])
}

// A percent band → grade letter (+ optional grade point for GPA). Bands within a
// scale must NOT overlap — enforced at the DB by a gist EXCLUDE (raw SQL), the same
// idiom AcademicTerm uses for date ranges (btree_gist already enabled). Ranges are
// half-open [minPercent, maxPercent); the top band's maxPercent uses a >100 sentinel
// (e.g. 100.01) so a perfect 100 still lands in a band (ADR-012 §3). A complete
// scale covers [0,100]; a percentage in no band is a misconfigured scale → the grade
// service rejects at LOCK (Step 5).
model GradeBand {
  id           String     @id @default(cuid())
  gradeScaleId String
  grade        String // A+, A, B+ ... E  (CONFIGURABLE — never hardcoded)
  minPercent   Float // inclusive lower bound
  maxPercent   Float // exclusive upper bound (top band uses a >100 sentinel)
  gradePoint   Float? // null → this scale has no GPA points
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  gradeScale   GradeScale @relation(fields: [gradeScaleId], references: [id], onDelete: Cascade)
  marks        Mark[]
  // + raw SQL: CHECK ("minPercent" >= 0 AND "maxPercent" > "minPercent")
  // + raw SQL: EXCLUDE USING gist ("gradeScaleId" WITH =, numrange("minPercent","maxPercent",'[)') WITH &&)
  //            — non-overlapping bands per scale (the "grade boundary" edge case, Step 9)

  @@unique([gradeScaleId, grade]) // a grade letter appears once per scale
  @@index([gradeScaleId])
}

// ========================= Homework & Assignment Management (M6) =========================
// ADR-013 is the source of truth (extends ADR-010/011/012 + ADR-004). Submissions key
// to Enrollment, NEVER Student — and the submitting actor is a PARENT (no student
// login exists). Grain: Homework (Subject × Section — the assignment IS the register;
// owns the DRAFT→PUBLISHED→CLOSED lifecycle, and PUBLISHED is the parent-visibility
// gate) → HomeworkSubmission (per Enrollment; unique (homework, enrollment); in-place
// resubmission via an attempt counter) with append-only SubmissionAttachment
// (attempt-tagged) and HomeworkFeedback (immutable review rounds). Ownership is
// DERIVED from TeacherAssignment(teacher, subject, section) at authz time — never
// stored; rows persist WHO ACTED (Staff/Parent actors, B3 invariant). Files live in
// the private `homework-files` bucket (ADR-004): *Path columns, signed per read
// after a business authz check — never URLs. dueDate is @db.Date (IST convention).

// ---------- enums ----------
// Homework lifecycle. Forward-only DRAFT→PUBLISHED→CLOSED with ONE audited backward
// transition: reopen (CLOSED→PUBLISHED, requires a reason — the M5 unlock analog).
// Submissions are accepted ONLY in PUBLISHED; review/feedback stay allowed in CLOSED.
enum HomeworkStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

// Submission lifecycle. SUBMITTED (awaiting review; parent may still resubmit) →
// RETURNED (changes requested; resubmit → back to SUBMITTED, attempt++) → REVIEWED
// (terminal accept — no resubmission after). Doubles as the feedback `decision`
// domain (RETURNED/REVIEWED only — CHECK below).
enum SubmissionStatus {
  SUBMITTED
  RETURNED
  REVIEWED
}

// ---------- homework (the assignment — Subject × Section; owns lifecycle + publication) ----------
// Always subject-bound: a (subject × section) pair is valid iff a TeacherAssignment
// exists for it (service check, M5 register idiom). academicYearId is stamped from
// the ACTIVE year at creation — the enforcement boundary for the cross-year
// invariant (submission.enrollment.academicYearId must match — ADR-013 §7; Subject/
// Section are year-agnostic, ADR-012 §10 precedent). Content (title/description/
// attachments) FREEZES at publish; dueDate is extend-only while PUBLISHED (service
// rules, ADR-013 §3). No ownerTeacherId — ownership derives at authz time; the four
// *ByStaffId columns are audit actors (B3), all Restrict. Lateness is snapshotted on
// the submission at (re)submit — there is NO auto-close cron; close is an explicit,
// audited action. Delete is business-guarded to DRAFT only (R5-analog; submissions
// require PUBLISHED, so a DRAFT structurally has none).
model Homework {
  id                 String               @id @default(cuid())
  schoolId           String // loose tenant ref (ADR-008)
  academicYearId     String
  subjectId          String
  sectionId          String
  title              String
  description        String? // optional body — attachments-only homework is legitimate
  dueDate            DateTime             @db.Date
  status             HomeworkStatus       @default(DRAFT)
  createdByStaffId   String
  publishedByStaffId String? // stamped on DRAFT→PUBLISHED
  publishedAt        DateTime?
  closedByStaffId    String? // stamped on PUBLISHED→CLOSED; CLEARED on reopen (reopen* + AuditLog keep history)
  closedAt           DateTime?
  reopenedByStaffId  String? // stamped on the audited reopen (CLOSED→PUBLISHED)
  reopenedAt         DateTime?
  reopenReason       String? // required by the service on reopen (ADR-013 §2)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  academicYear       AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  subject            Subject              @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  section            Section              @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  createdBy          Staff                @relation("HomeworkCreatedBy", fields: [createdByStaffId], references: [id], onDelete: Restrict)
  publishedBy        Staff?               @relation("HomeworkPublishedBy", fields: [publishedByStaffId], references: [id], onDelete: Restrict)
  closedBy           Staff?               @relation("HomeworkClosedBy", fields: [closedByStaffId], references: [id], onDelete: Restrict)
  reopenedBy         Staff?               @relation("HomeworkReopenedBy", fields: [reopenedByStaffId], references: [id], onDelete: Restrict)
  attachments        HomeworkAttachment[]
  submissions        HomeworkSubmission[]
  // No natural unique: two same-titled homeworks for one section/day are legal (deliberate).
  // + raw SQL: CHECK — (status = DRAFT) ⟺ (publishedAt IS NULL): the visibility gate can't drift from its stamp
  // + raw SQL: CHECK — (status = CLOSED) ⟺ (closedAt IS NOT NULL): reopen clears the close stamp
  // + raw SQL: RLS ON — admin ALL; teacher own subject×section; parent published own-child (homework_rls, Step 4)

  @@index([sectionId, status, dueDate]) // hot path: a section's open homework by due date (parent/teacher feed)
  @@index([academicYearId, sectionId]) // year-scoped section listing
  @@index([subjectId])
  @@index([schoolId])
}

// ---------- homework attachment (teacher files; metadata — bytes in Storage) ----------
// Add/remove ONLY while DRAFT (content freezes at publish — service rule). Rows are
// immutable once written (no updatedAt — the StudentDocument idiom). storagePath is
// a PRIVATE homework-files bucket path, server-chosen
// (`{schoolId}/homework/{homeworkId}/{uuid}-{name}` — ADR-004), signed per read.
// Cascade from Homework: attachments are its content; deletion is business-guarded
// to DRAFT-only, so the chain can only ever wipe teacher-side draft content.
model HomeworkAttachment {
  id                String   @id @default(cuid())
  schoolId          String // loose tenant ref (ADR-008)
  homeworkId        String
  storagePath       String // PRIVATE bucket path (ADR-004), signed on read
  fileName          String
  mimeType          String?
  sizeBytes         Int?
  checksum          String? // optional SHA-256 hex — integrity check on download
  uploadedByStaffId String
  createdAt         DateTime @default(now()) // == uploadedAt (row written at upload; immutable)
  homework          Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  uploadedBy        Staff    @relation("HomeworkAttachmentUploadedBy", fields: [uploadedByStaffId], references: [id], onDelete: Restrict)
  // + raw SQL: RLS ON — mirrors Homework visibility (homework_rls, Step 4)

  @@index([homeworkId])
  @@index([schoolId])
}

// ---------- homework submission (per ENROLLMENT — one row per child per assignment) ----------
// enrollmentId is the ONLY link to a student (ADR-010 §8) — no studentId column;
// history survives promotion by construction. The submitting actor is a PARENT; the
// service enforces the cross-table invariants the DB cannot (ADR-013 §7): section
// match, year match, ACTIVE enrollment, StudentParent link, homework PUBLISHED.
// Resubmission mutates THIS row in place (attempt++, status→SUBMITTED, note/
// submittedAt/isLate refreshed) — never a second row (the unique forbids it);
// attachments + feedback are append-only children, so history needs no version
// table. isLate is a SNAPSHOT of the LATEST attempt vs dueDate (IST) — no cron.
// Review-vs-resubmit races settle via guarded (status, attempt) conditional
// updates (M4 idiom) — a lost race is a Conflict, never a silent overwrite.
model HomeworkSubmission {
  id                  String                 @id @default(cuid())
  schoolId            String // loose tenant ref (ADR-008)
  homeworkId          String
  enrollmentId        String
  submittedByParentId String // WHO submitted the latest attempt (either linked parent may act)
  note                String? // optional parent message; empty submission (no note, no files) is service-rejected
  status              SubmissionStatus       @default(SUBMITTED)
  attempt             Int                    @default(1)
  isLate              Boolean                @default(false)
  firstSubmittedAt    DateTime // stamped once at attempt 1, never touched again
  submittedAt         DateTime // latest (re)submission
  reviewedByStaffId   String? // stamped on each RETURNED/REVIEWED decision (kept through a resubmit)
  reviewedAt          DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  homework            Homework               @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  enrollment          Enrollment             @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  submittedBy         Parent                 @relation(fields: [submittedByParentId], references: [id], onDelete: Restrict)
  reviewedBy          Staff?                 @relation("SubmissionReviewedBy", fields: [reviewedByStaffId], references: [id], onDelete: Restrict)
  attachments         SubmissionAttachment[]
  feedback            HomeworkFeedback[]
  // + raw SQL: CHECK ("attempt" >= 1)
  // + raw SQL: CHECK ("firstSubmittedAt" <= "submittedAt")
  // + raw SQL: CHECK — a decision state (RETURNED/REVIEWED) always carries reviewedBy/reviewedAt
  // + raw SQL: RLS ON — admin ALL; teacher own subject×section; parent own-child (homework_rls, Step 4)

  @@unique([homeworkId, enrollmentId]) // ONE submission per child per assignment — the duplicate race is a DB error (ADR-013 §5)
  @@index([enrollmentId]) // child's homework trail (per-year slices under each enrollment)
  @@index([homeworkId, status]) // teacher review queue (one homework's submissions by state)
  @@index([schoolId])
}

// ---------- submission attachment (parent files; APPEND-ONLY, attempt-tagged) ----------
// Resubmission never deletes prior files' metadata — "the parent did submit X on
// attempt 1" must stay answerable (disputes; ADR-013 §6). Reads default to the
// latest attempt. Rows are immutable once written (no updatedAt). storagePath is
// server-chosen (`{schoolId}/submission/{submissionId}/{attempt}/{uuid}-{name}`).
// Cascade from submission (its content); the submission itself is delete-guarded
// via Homework (DRAFT-only), so no published child data can cascade away.
model SubmissionAttachment {
  id                 String             @id @default(cuid())
  schoolId           String // loose tenant ref (ADR-008)
  submissionId       String
  attempt            Int // which attempt this file belongs to (append-only history)
  storagePath        String // PRIVATE bucket path (ADR-004), signed on read
  fileName           String
  mimeType           String?
  sizeBytes          Int?
  checksum           String? // optional SHA-256 hex — integrity check on download
  uploadedByParentId String
  createdAt          DateTime           @default(now()) // == uploadedAt (immutable row)
  submission         HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  uploadedBy         Parent             @relation(fields: [uploadedByParentId], references: [id], onDelete: Restrict)
  // + raw SQL: CHECK ("attempt" >= 1)
  // + raw SQL: RLS ON — admin ALL; teacher own subject×section; parent own-child (homework_rls, Step 4)

  @@index([submissionId, attempt]) // latest-attempt reads + per-round history
  @@index([schoolId])
}

// ---------- homework feedback (immutable review rounds) ----------
// The M4-correction discipline: an append-only historical assertion, never edited
// or deleted (no updatedAt). Writing a row + transitioning the submission
// (RETURNED/REVIEWED + reviewedBy/At stamps) + the AuditLog row happen in ONE
// transaction (ADR-007). `decision` snapshots the round's outcome (RETURNED or
// REVIEWED — never SUBMITTED, CHECK below); `attempt` pins which attempt was
// judged. Text only — NO score/grade fields (grading is out of scope, ADR-013 §8).
// Parent-visible immediately: the review decision IS the publication act.
model HomeworkFeedback {
  id            String             @id @default(cuid())
  schoolId      String // loose tenant ref (ADR-008)
  submissionId  String
  authorStaffId String
  attempt       Int // which attempt this round reviewed (snapshot)
  decision      SubmissionStatus // RETURNED or REVIEWED (snapshot of the round's outcome)
  body          String
  createdAt     DateTime           @default(now())
  submission    HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author        Staff              @relation("HomeworkFeedbackAuthor", fields: [authorStaffId], references: [id], onDelete: Restrict)
  // + raw SQL: CHECK ("attempt" >= 1)
  // + raw SQL: CHECK ("decision" <> 'SUBMITTED') — a feedback round records an outcome
  // + raw SQL: RLS ON — admin ALL; teacher own subject×section; parent own-child (homework_rls, Step 4)

  @@index([submissionId])
  @@index([schoolId])
}

// ========================= Class Teacher Management (M6.5) =========================
// ClassTeacherAssignment (ADR-015) — the CURRENT holder of the class-teacher slot
// for a (academicYear × section). DELIBERATELY a dedicated model, NOT a flag on
// TeacherAssignment: a teacher may teach several subjects in a section (which of
// those rows would carry the flag?) and a class teacher may teach NO subject in
// their section at all. So class-teacher-ship is its own fact: (year × section) →
// ONE teacher.
//
// YEAR-SCOPED (diverges from the non-year-scoped TeacherAssignment): each year gets
// its own row, so CROSS-YEAR history is preserved by construction (ADR-010 per-year
// rows). WITHIN a year the row is UPDATED IN PLACE when the class teacher changes
// (ADR-010 §5 mid-year-transfer philosophy); AuditLog carries the change history —
// NO endedAt, NO isActive, NO second row (there is always exactly one row per
// (year, section), enforced by @@unique below). `teacherId → User` mirrors
// TeacherAssignment's RLS idiom (teacherId = auth.uid()). `assignedAt` = when the
// CURRENT teacher took the slot (re-stamped to now() on assign AND replace; prior
// values live in the AuditLog before-image). `createdByStaffId → Staff` = the acting
// staff who assigned (B3 audit actor). Managed by admins under `academic:manage`;
// the remark-authoring gate is the business-layer predicate isClassTeacherOfEnrollment.
model ClassTeacherAssignment {
  id               String       @id @default(cuid())
  schoolId         String // loose tenant ref (ADR-008)
  academicYearId   String
  sectionId        String
  teacherId        String // → User (like TeacherAssignment.teacherId; RLS checks teacherId = auth.uid())
  assignedAt       DateTime     @default(now()) // when the CURRENT teacher took the slot (re-stamped on replace)
  createdByStaffId String // → Staff — acting staff who assigned/replaced (B3 audit actor)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  academicYear     AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  section          Section      @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  teacher          User         @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  createdBy        Staff        @relation("ClassTeacherAssignedBy", fields: [createdByStaffId], references: [id], onDelete: Restrict)
  // + raw SQL: RLS ON — admin ALL; teacher SELECT own (teacherId = auth.uid()) (class_teacher_assignment migration)

  @@unique([academicYearId, sectionId]) // exactly ONE class teacher per section per year (UPDATE, never a 2nd row)
  @@index([teacherId])
  @@index([schoolId])
}

// ========================= Report Cards & Academic Results (M7) =========================
// ADR-014 is the source of truth (extends ADR-009 examId-nullable + partial-unique).
// The card OWNER is Enrollment (ADR-010 §8) — never Student, never Exam/Term/Year
// (those are SCOPE attributes). M7 is a pure REPORTING layer over frozen M3–M6: it
// SNAPSHOTS the compute-on-read (attendance %) and cohort-relative (rank) values plus
// its own authored fields (remarks, promotion decision), and COPIES the already-immutable
// upstream numbers (GPA) for display only — it never re-owns marks/attendance.
//
// Locked product decisions (R1/R2/R3):
//  R1 — the CLASS TEACHER (ADR-015 ClassTeacherAssignment; gate isClassTeacherOfEnrollment)
//       drafts the classTeacherRemark and SUBMITS for review; OFFICE_ADMIN/SUPER_ADMIN
//       APPROVE, PUBLISH, REOPEN, REVOKE. A subject teacher never edits a card.
//  R2 — rank is STORED (frozen value + its rankScope cohort). Own-rank-only visibility
//       and a future "hide rank" school setting are APP-LAYER concerns — NO schema flag.
//  R3 — PUBLISHED cards are immutable; a correction creates a NEW version (version++),
//       the prior PUBLISHED row → SUPERSEDED (retained). Every publish/correction is
//       written to AuditLog by the SERVICE (ADR-007) — no column here.

// ---------- enums ----------
// Card scope discriminator (ADR-009's deferred extension point, now required).
// EXAM → examId set; TERM → termId set; ANNUAL → neither (year comes from enrollment).
// Each brings its OWN per-kind uniqueness rule (raw SQL below) — the designed seam
// for future board formats (CBSE/ICSE/semester), ADR-014 §10.
enum ReportCardKind {
  EXAM
  TERM
  ANNUAL
}

// Publication lifecycle (ADR-014 §2 + R1's review gap). Forward-only, audited.
//   DRAFT ──submit──▶ SUBMITTED ──approve──▶ APPROVED ──publish──▶ PUBLISHED
//     ▲                   │                     │
//     └──── reopen ◀───────┴─────────────────────┘   (clears submit/approve stamps)
//   PUBLISHED ──supersede──▶ SUPERSEDED  (a correction's new version; R3)
//   PUBLISHED ──revoke────▶ REVOKED      (pulled from parents, no replacement; R1)
// APPROVED == ADR-014 §2's "GENERATED" (snapshot frozen + PDF rendered, not yet
// parent-visible) — renamed to match R1's "approve" verb; see the Step-10 doc note.
// Parent-visibility gate is exactly PUBLISHED (ADR-012 idiom).
enum ReportCardStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PUBLISHED
  SUPERSEDED
  REVOKED
}

// The cohort a snapshotted rank was computed over — frozen WITH the value (R2/ADR-014
// §3): a later transfer/scope change is non-retroactive by construction.
enum RankScope {
  SECTION
  CLASS
}

// The promotion outcome as SHOWN on the card (ANNUAL). The card RECORDS this decision;
// it does NOT perform promotion — that is a separate Enrollment mutation (ADR-010 §4,
// promoteBulk). One-directional: enrollment lifecycle → card content, never card →
// enrollment (ADR-014 §8).
enum PromotionDecision {
  PROMOTED
  RETAINED
}

// ---------- report card (Enrollment-owned; ADR-014) ----------
// enrollmentId is the ONLY link to a student (ADR-010 §8) — no studentId/academicYearId
// column (year is one hop via enrollment). All snapshot fields are NULL in DRAFT/SUBMITTED
// and FROZEN at APPROVE (== §2 GENERATED). pdfPath is service-set and DELIBERATELY not
// tied to any lifecycle CHECK — the private report-card bucket is runbook-provisioned
// (ADR-014 R5), and a storage dependency must never be able to block a status transition.
// The structured card view reads THESE snapshot fields + the PDF link ONLY — it must
// NOT re-join live Mark rows: an ADR-012 unlock→edit→lock after publish would drift the
// re-joined grades from the frozen card (precisely why a correction is a NEW version, R3,
// not an in-place read). Per-subject grade rows are deliberately NOT snapshotted into a
// child table (ADR-014 Alternative #3 — marks are already immutable upstream, ADR-012 §3;
// the PDF holds the rendered table, gpaSnapshot holds the queryable aggregate).
// All *ByStaffId are audit actors (B3 invariant), all Restrict. RLS is Step 4.
model ReportCard {
  id           String           @id @default(cuid())
  schoolId     String // loose tenant ref (ADR-008)
  enrollmentId String
  kind         ReportCardKind
  examId       String? // EXAM cards (ADR-009 nullable; kind⟺scope CHECK + per-kind unique below)
  termId       String? // TERM cards
  version      Int              @default(1) // R3: bumps per correction; (scope, version) is unique per kind
  status       ReportCardStatus @default(DRAFT)

  // ---- card-owned authored fields (system of record; ADR-014 §3) ----
  classTeacherRemark String? // R1: authored by the class teacher (ADR-015 gate), editable in DRAFT
  principalRemark    String? // office/principal comment
  promotionDecision  PromotionDecision? // stated outcome shown to parent (ANNUAL); ADR-014 §3/§8

  // ---- snapshot: frozen at APPROVE (ADR-014 §3) ----
  rank                 Int? // cohort rank, frozen (R2)
  rankScope            RankScope? // the cohort the rank was computed over (frozen WITH the value)
  cohortSize           Int? // "rank of N"
  attendancePercentage Float? // weighted %, compute-on-read (ADR-011) → MUST snapshot
  presentCount         Int?
  absentCount          Int?
  lateCount            Int?
  halfDayCount         Int?
  leaveCount           Int? // LEAVE is excluded from the % denominator (ADR-011 weighting)
  workingDays          Int? // sessions counted (denominator)
  gpaSnapshot          Float? // display copy of gpaForEnrollment — already immutable upstream (ADR-012 §3)
  cgpaSnapshot         Float?
  pdfPath              String? // PRIVATE bucket, signed-on-read (ADR-004); service-set, NOT lifecycle-gating

  // ---- lifecycle actors + stamps (B3: all → Staff, Restrict) ----
  createdByStaffId   String
  submittedByStaffId String? // DRAFT→SUBMITTED (class teacher submits for review); CLEARED on reopen
  submittedAt        DateTime?
  approvedByStaffId  String? // SUBMITTED→APPROVED (snapshot frozen + PDF); CLEARED on reopen
  approvedAt         DateTime?
  publishedByStaffId String? // APPROVED→PUBLISHED (parent-visible)
  publishedAt        DateTime?
  reopenedByStaffId  String? // audited reopen (SUBMITTED/APPROVED→DRAFT); clears submit/approve stamps
  reopenedAt         DateTime?
  reopenReason       String? // required by the service on reopen (homework idiom)
  revokedByStaffId   String? // PUBLISHED→REVOKED (pull a published card)
  revokedAt          DateTime?
  revokeReason       String? // required by the service on revoke

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollment  Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  exam        Exam?         @relation(fields: [examId], references: [id], onDelete: Restrict)
  term        AcademicTerm? @relation(fields: [termId], references: [id], onDelete: Restrict)
  createdBy   Staff         @relation("ReportCardCreatedBy", fields: [createdByStaffId], references: [id], onDelete: Restrict)
  submittedBy Staff?        @relation("ReportCardSubmittedBy", fields: [submittedByStaffId], references: [id], onDelete: Restrict)
  approvedBy  Staff?        @relation("ReportCardApprovedBy", fields: [approvedByStaffId], references: [id], onDelete: Restrict)
  publishedBy Staff?        @relation("ReportCardPublishedBy", fields: [publishedByStaffId], references: [id], onDelete: Restrict)
  reopenedBy  Staff?        @relation("ReportCardReopenedBy", fields: [reopenedByStaffId], references: [id], onDelete: Restrict)
  revokedBy   Staff?        @relation("ReportCardRevokedBy", fields: [revokedByStaffId], references: [id], onDelete: Restrict)
  // + raw SQL: CHECK — kind⟺scope (EXAM⟹examId set/termId null; TERM⟹termId set/examId null; ANNUAL⟹both null)
  // + raw SQL: CHECK — snapshot-iff-approved: (approvedAt IS NULL) = (status IN DRAFT,SUBMITTED)  [reopen clears approvedAt]
  // + raw SQL: CHECK — publishedAt set ⟺ status has-been-published (PUBLISHED,SUPERSEDED,REVOKED)
  // + raw SQL: CHECK — revokedAt set ⟺ status = REVOKED
  // + raw SQL: CHECK — version >= 1; rank/cohortSize >= 1 and rank <= cohortSize; percentage 0..100; gpa/cgpa >= 0
  // + raw SQL: partial unique per kind — ONE PUBLISHED per scope (R3): supersede-then-publish in ONE tx (service).
  //            "one ACTIVE draft per scope" is deliberately a SERVICE invariant, not structural (M6 cross-row stance).
  // + raw SQL: partial unique per kind — (scope, version) so two corrections can't collide on a version (R3)
  // + raw SQL: RLS ON — admin ALL; class-teacher own-section; parent PUBLISHED own-child (report_card_rls, Step 4)

  @@index([enrollmentId]) // student's card trail (parent read + Q6 year-over-year comparison)
  @@index([enrollmentId, kind])
  @@index([examId])
  @@index([termId])
  @@index([status]) // admin review/publish queues
  @@index([schoolId])
}
