# School Management Portal — environment template (Dev PRD §11).
# Copy to `.env` and fill real values. NEVER commit `.env`. Validation is
# strongly typed in apps/web/src/env.ts and apps/mobile/src/env.ts (fail-fast).

# Which environment this process represents.
APP_ENV="development" # development | staging | production

# ---- Database / Supabase (server-only) ----
DATABASE_URL="postgresql://user:password@localhost:5432/school_portal?schema=public"
SUPABASE_SERVICE_ROLE="" # service role key — server only, NEVER exposed to clients

# ---- Supabase (public — safe for the browser/app) ----
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ---- Mobile (Expo) public env — only EXPO_PUBLIC_* is bundled ----
EXPO_PUBLIC_APP_ENV="development"
EXPO_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY=""
EXPO_PUBLIC_API_URL="http://localhost:3000"

# ---- Integrations (added as the relevant modules land; see Dev PRD §11) ----
# RAZORPAY_KEY_ID=""              # fees add-on
# RAZORPAY_KEY_SECRET=""          # fees add-on (server only)
# MSG91_API_KEY=""                # SMS/OTP provider
# GUPSHUP_API_KEY=""              # WhatsApp/SMS provider
# RESEND_API_KEY=""               # transactional email
# SENTRY_DSN=""
# POSTHOG_KEY=""

# CI / tooling: set true to let build/typecheck run without real env values.
# SKIP_ENV_VALIDATION="true"

# ---- Bootstrap / live verification (ops scripts — packages/business/scripts) ----
SEED_SCHOOL_NAME="My School"
SEED_SUPER_ADMIN_EMAIL="admin@example.com"
SEED_SUPER_ADMIN_PASSWORD="" # >= 10 chars
TEST_OTP_PHONE="+919999900001" # must match the Supabase test OTP config
TEST_OTP_CODE="123456"
