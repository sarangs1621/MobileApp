# dependencies
node_modules/
.pnpm-store/

# build outputs
dist/
.next/
out/
.expo/
expo-dist/
*.tsbuildinfo

# turbo
.turbo/

# test / coverage
coverage/
playwright-report/
test-results/

# prisma
packages/db/prisma/*.db

# env (never commit secrets)
.env
.env.*
!.env.example
LOGIN.local.md

# expo generated
apps/mobile/expo-env.d.ts
apps/mobile/.expo/

# expo prebuild (CNG) native projects — regenerated by `expo prebuild` / EAS, never committed
apps/mobile/android/
apps/mobile/ios/

# scratch / previews (throwaway working files)
.scratch-preview/
scratch/
*.tmp

# throwaway / personal docs (keep real project docs tracked; ignore only ephemeral ones)
*.local.md
*.draft.md
*.scratch.md
*.tmp.md
NOTES.local.md
TODO.local.md

# throwaway QA handoff (temporary — untracked at go-live, remove before production)
QA_E2E_HANDOFF.md

# local-only Claude settings (personal overrides — shared config stays tracked)
.claude/settings.local.json
.claude/**/*.local.json

# misc
.DS_Store
*.log
.idea/
.vscode/*
!.vscode/extensions.json
graphify-out/

# OS junk (Windows / macOS)
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
